# Получить у @BotFather
BOT_TOKEN=PASTE_TELEGRAM_BOT_TOKEN_HERE

# Ваши Telegram user id через запятую. Узнать можно у @userinfobot.
ADMIN_IDS=111111111,222222222

# Готовая база уже лежит тут. Можно не менять.
DATABASE_PATH=data/bot.sqlite3

# Если хотите импортировать новый экспорт Simply Plural, положите файл сюда.
SP_EXPORT_PATH=data/simply_plural_export.json

# true = при старте пробовать импортировать SP_EXPORT_PATH, если файл существует.
# Для готовой базы можно оставить false.
AUTO_IMPORT_ON_START=false

# true = обычным пользователям показывать private/archived фронтеров, если админ поставил их на фронт.
# По умолчанию true, потому что вы просили не упускать никого.
PUBLIC_SHOW_PRIVATE=true
PUBLIC_SHOW_ARCHIVED=true

# Максимум вариантов при поиске личности.
SEARCH_LIMIT=12
